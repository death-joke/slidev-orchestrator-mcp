{
  "name": "slidev-orchestrator-mcp",
  "version": "0.1.0",
  "description": "MCP server to orchestrate multiple Slidev presentations: list, create, run dev servers, and proxy the official Slidev MCP tools per presentation.",
  "keywords": [],
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "release": "commit-and-tag-version",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "author": "",
  "license": "ISC",
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "slidev-orchestrator-mcp": "dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
